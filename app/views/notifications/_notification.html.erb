<% if notification.notifiable_type == "Comment" %>
  <% comment = notification.notifiable %>
  <% url = comment ? ferment_path(comment.ferment_id) + "##{dom_id(comment)}" : notifications_path %>
<% elsif notification.notifiable_type == "Message" %>
  <% url = notification.notifiable ? message_path(notification.notifiable) : notifications_path %>
<% else %>
  <% url = notifications_path %>
<% end %>

<div class="d-flex align-items-center position-relative">

  <%= button_to mark_as_read_notification_path(notification),
                method: :patch,
                form: { data: { turbo: true } },
                id: dom_id(notification),
                class: "notification-item d-flex align-items-center gap-2 text-decoration-none p-3 border-bottom border-warning w-100 text-start bg-transparent border-0 #{notification.read? ? 'opacity-60' : 'bg-warning bg-opacity-10'}" do %>

    <% if notification.actor.photo.attached? %>
      <%= image_tag notification.actor.photo, class: "rounded-circle", style: "width:40px;height:40px;object-fit:cover" %>
    <% else %>
      <i class="bi bi-person-circle fs-4 text-secondary"></i>
    <% end %>

    <div>
      <p class="mb-0 small text-light"><%= notification.message %></p>
      <span class="text-light mt-0" style="font-size:0.75rem"><%= time_ago_in_words(notification.created_at) %> atrás</span>
    </div>

    <% unless notification.read? %>
      <span class="ms-auto bg-warning rounded-circle" style="width:8px;height:8px;flex-shrink:0"></span>
    <% end %>

  <% end %>

  <%= button_to notification_path(notification),
                method: :delete,
                form: { data: { turbo: true } },
                class: "btn btn-sm text-secondary border-0 bg-transparent",
                title: "Eliminar" do %>
    <i class="bi bi-x fs-5"></i>
  <% end %>

</div>
